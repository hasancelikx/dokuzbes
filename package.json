{
  "name": "dokuzbes-mono",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:services": "bash dev.sh",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "cd packages/db-client && npx prisma migrate dev",
    "db:generate": "cd packages/db-client && npx prisma generate",
    "db:studio": "cd packages/db-client && npx prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.0",
    "@types/node": "^20.0.0"
  }
}
